# Examiner AI - Environment Configuration

# REQUIRED: Groq API key for AI question parsing + evaluation
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Groq model choices (defaults shown - override if needed)
GROQ_MODEL_PARSING=llama-3.3-70b-versatile
GROQ_MODEL_VISION=llama-3.2-11b-vision-preview

# OPTIONAL: Local Ollama URL for GLM-OCR (scanned PDF / image OCR)
# Defaults to http://localhost:11434 if not set
# Install: https://ollama.ai  ->  ollama pull glm-ocr:latest
NEXT_PUBLIC_OLLAMA_URL=http://localhost:11434
NEXT_PUBLIC_OLLAMA_OCR_MODEL=glm-ocr:latest

# Groq Free Tier Rate Limits:
# llama-3.3-70b-versatile:  30 RPM, 30,000 TPM
# llama-3.2-11b-vision:     30 RPM, 7,000 TPM
